---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HeroMesh from '../components/HeroMesh.astro';
import HeroTopology from '../components/HeroTopology.astro';
import ToolLogoStrip from '../components/ToolLogoStrip.astro';
import PinnedSequence from '../components/PinnedSequence.astro';
import TestimonialMarquee from '../components/TestimonialMarquee.astro';
import CtaBand from '../components/CtaBand.astro';
import { btnPrimary, btnSecondary } from '../lib/ui';

const painCards = [
  {
    title: 'Follow-ups keep dropping.',
    body: "Leads go cold because nobody's system said to reply. Your close rate has a ceiling you can't see.",
  },
  {
    title: "I can't see what my team is doing.",
    body: "You ask, they answer, you're not sure. Status meetings replaced the actual work.",
  },
  {
    title: 'I build the same report every Monday.',
    body: 'Two hours of copy-paste to answer one question: how are we doing? That\'s four full weeks a year.',
  },
  {
    title: 'Five tools. None of them talk.',
    body: 'Sales in one place, delivery in another, finance somewhere else. The gaps are where money leaks.',
  },
];

const steps = [
  {
    number: '01',
    title: 'Audit',
    subtitle: '5 days, fixed fee',
    body: 'We map your workflows, quantify the biggest time and money leaks, and hand you a prioritized 90-day roadmap. Fee credited back if you build with us.',
  },
  {
    number: '02',
    title: 'Build',
    subtitle: 'fixed timeline, fixed price',
    body: 'We build what the audit prioritized, in the order it prioritized. Weekly demos. No open-ended hourly billing.',
  },
  {
    number: '03',
    title: 'Care Plan',
    subtitle: 'monthly, cancel anytime',
    body: "We monitor, maintain, and extend what we built. Because a system nobody's watching is a system about to break.",
  },
];
---

<Layout
  title="Duten Nexa - Operating systems for growing companies"
  description="Follow-ups drop. Reports take half a day. Tools don't talk. Duten Nexa builds the operating systems that let UK/US SMBs scale without chaos. Book a 5-day Automation Audit."
  ogImage="/brand/logo-teal.png"
>
  <Nav />
  <main>
    <!-- 1. Hero (Command Deck) -->
    <section class="relative isolate overflow-hidden bg-grad-hero">
      <HeroMesh />
      <div class="relative z-10 mx-auto max-w-6xl px-5 pb-16 pt-28 md:pb-20 md:pt-36">
        <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2">
          <div>
            <span class="cursor-ai inline-flex items-center gap-2 rounded-full border border-border-violet bg-violet/10 px-3 py-1 text-xs font-semibold tracking-[0.1em] text-violet-text">
              <span class="ai-pulse inline-block h-1.5 w-1.5 rounded-full bg-violet"></span>
              AI-NATIVE OPERATING SYSTEMS
            </span>

            <h1 class="mt-5 text-h1 text-white">
              Growing your business is making it <span class="grad-text">harder to run.</span>
            </h1>

            <p class="mt-6 max-w-xl leading-relaxed text-text-dim">
              Follow-ups drop. Handoffs break. We build the intelligent operating system that
              scales, so the chaos doesn't.
            </p>

            <div class="mt-8 flex flex-wrap gap-4">
              <a href="/audit" class={`cursor-button ${btnPrimary}`}>Book an Automation Audit →</a>
              <a href="/scorecard" class={`cursor-button ${btnSecondary}`}>Take the Scorecard</a>
            </div>

            <div class="mt-10 flex flex-wrap gap-x-10 gap-y-6">
              <div>
                <p class="text-3xl font-bold">
                  <span class="grad-text tabular-nums inline-block min-w-[3ch]" data-count="75" data-suffix="%">75%</span>
                </p>
                <p class="mt-1 text-sm text-text-dim">less manual reporting</p>
              </div>
              <div>
                <p class="text-3xl font-bold">
                  <span class="align-baseline text-base font-medium text-text-dim">up to</span>{' '}
                  <span class="grad-text tabular-nums inline-block min-w-[2.5ch]" data-count="80" data-suffix="%">80%</span>
                </p>
                <p class="mt-1 text-sm text-text-dim">fewer repetitive tasks</p>
              </div>
              <div>
                <p class="text-3xl font-bold">
                  <span class="grad-text-ai tabular-nums inline-block min-w-[1.5ch]" data-count="5" data-suffix=" days">5 days</span>
                </p>
                <p class="mt-1 text-sm text-text-dim">audit turnaround</p>
              </div>
            </div>
          </div>

          <div class="flex justify-center">
            <HeroTopology />
          </div>
        </div>
      </div>
    </section>

    <!-- 1a. Tool logo strip -->
    <ToolLogoStrip />

    <!-- 2. The problem -->
    <section class="bg-navy py-16 md:py-24">
      <div class="mx-auto max-w-6xl px-5">
        <div class="reveal max-w-2xl" data-reveal>
          <h2 class="text-h2 text-white">Sound familiar?</h2>
          <p class="mt-4 text-text-dim">
            Every growing SMB hits the same wall around $500K in revenue. Not because the market
            isn't there, but because the inside of the business can't keep up with what the
            outside is doing.
          </p>
        </div>

        <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2">
          {painCards.map((card, i) => (
            <div
              class="tilt-card reveal rounded-xl border border-border-soft bg-surface-card p-6 transition-[border-color] duration-200"
              data-reveal
              style={`transition-delay:${i * 90}ms`}
            >
              <h3 class="text-lg font-semibold text-white">{card.title}</h3>
              <p class="mt-3 text-sm text-text-dim">{card.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 3. What we build (pinned scrollytelling sequence) -->
    <PinnedSequence />

    <!-- 4. Proof strip -->
    <section id="proof" class="overflow-hidden bg-navy py-16 md:py-24">
      <div class="mx-auto max-w-6xl px-5">
        <h2 class="reveal text-h2 text-white" data-reveal>Founders like you, work we've shipped.</h2>
      </div>
      <div class="mt-12">
        <TestimonialMarquee />
      </div>
    </section>

    <!-- 5. How it works -->
    <section id="how-it-works" class="bg-navy-800 py-16 md:py-24">
      <div class="mx-auto max-w-6xl px-5">
        <h2 class="reveal text-h2 text-center text-white" data-reveal>Three steps. No surprises.</h2>

        <div class="relative mt-14">
          <div class="pointer-events-none absolute left-0 right-0 top-8 -z-10 hidden md:block" aria-hidden="true">
            <div class="line-draw h-px w-full bg-gradient-to-r from-indigo to-teal" data-reveal></div>
          </div>

          <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            {steps.map((step, i) => (
              <div
                class="reveal relative rounded-xl border border-border-soft bg-surface-card p-6"
                data-reveal
                style={`transition-delay:${i * 120}ms`}
              >
                <span class="grad-text text-sm font-bold">{step.number}</span>
                <h3 class="mt-2 text-lg font-semibold text-white">{step.title} - {step.subtitle}</h3>
                <p class="mt-3 text-sm text-text-dim">{step.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- 6. Featured case study (AI-tinted) -->
    <section class="bg-navy py-16 md:py-24">
      <div class="mx-auto max-w-6xl px-5">
        <div
          class="cursor-ai tilt-lift reveal relative overflow-hidden rounded-2xl bg-grad-ai p-8 md:p-12"
          data-reveal
        >
          <div class="case-particles pointer-events-none absolute inset-0 overflow-hidden" data-parallax="0.6" aria-hidden="true">
            {[
              { top: '12%', left: '18%', size: 5, dur: 6.5 },
              { top: '68%', left: '8%', size: 3, dur: 8 },
              { top: '30%', left: '85%', size: 4, dur: 7.2 },
              { top: '80%', left: '92%', size: 6, dur: 5.8 },
              { top: '50%', left: '48%', size: 3, dur: 9 },
              { top: '15%', left: '60%', size: 4, dur: 6.8 },
            ].map((p) => (
              <span
                class="case-particle absolute"
                style={`top:${p.top}; left:${p.left}; width:${p.size}px; height:${p.size}px; animation-duration:${p.dur}s`}
              ></span>
            ))}
          </div>
          <div class="relative">
            <p class="text-sm font-semibold uppercase tracking-wide text-mint">Case study, Nerbugs · USA</p>
            <blockquote class="mt-4 max-w-3xl text-h2 text-white">
              &ldquo;The pipeline stopped leaking.&rdquo;
            </blockquote>
            <p class="mt-4 max-w-2xl text-text-dim">
              Optimized ClickUp workspace, Apollo CRM integration, Make automations for follow-up
              emails and sales workflows, and live sales dashboards for real-time decisions.
              <span class="mt-2 block text-sm text-text-faint">Dr. Ronak Mehta, Founder, Nerbugs</span>
            </p>
            <a href="/case-studies/nerbugs" class="cursor-link mt-6 inline-block font-medium text-mint hover:underline">
              Read the case study →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 7. Final CTA band -->
    <CtaBand />
  </main>
  <Footer />
</Layout>
