---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HeroMesh from '../components/HeroMesh.astro';
import HeroStack from '../components/HeroStack.astro';
import OSLayers from '../components/OSLayers.astro';
import TestimonialMarquee from '../components/TestimonialMarquee.astro';

const btnPrimary =
  'inline-flex items-center justify-center rounded-lg bg-grad-accent px-6 py-3 font-medium text-navy transition-[transform,filter] duration-200 hover:scale-[1.02] hover:brightness-105';
const btnSecondary =
  'inline-flex items-center justify-center rounded-lg border border-teal px-6 py-3 font-medium text-teal transition-colors duration-200 hover:bg-teal/10';

const painCards = [
  {
    title: 'Follow-ups keep dropping.',
    body: "Leads go cold because nobody's system said to reply. Your close rate has a ceiling you can't see.",
  },
  {
    title: "I can't see what my team is doing.",
    body: "You ask, they answer, you're not sure. Status meetings replaced the actual work.",
  },
  {
    title: 'I build the same report every Monday.',
    body: 'Two hours of copy-paste to answer one question: how are we doing? That\'s four full weeks a year.',
  },
  {
    title: 'Five tools. None of them talk.',
    body: 'Sales in one place, delivery in another, finance somewhere else. The gaps are where money leaks.',
  },
];

const steps = [
  {
    number: '01',
    title: 'Audit',
    subtitle: '5 days, fixed fee',
    body: 'We map your workflows, quantify the biggest time and money leaks, and hand you a prioritized 90-day roadmap. Fee credited back if you build with us.',
  },
  {
    number: '02',
    title: 'Build',
    subtitle: 'fixed timeline, fixed price',
    body: 'We build what the audit prioritized, in the order it prioritized. Weekly demos. No open-ended hourly billing.',
  },
  {
    number: '03',
    title: 'Care Plan',
    subtitle: 'monthly, cancel anytime',
    body: "We monitor, maintain, and extend what we built. Because a system nobody's watching is a system about to break.",
  },
];
---

<Layout
  title="Duten Nexa - Operating systems for growing companies"
  description="Follow-ups drop. Reports take half a day. Tools don't talk. Duten Nexa builds the operating systems that let UK/US SMBs scale without chaos. Book a 5-day Automation Audit."
  ogImage="/brand/logo-teal.png"
>
  <Nav />
  <main>
    <!-- 1. Hero -->
    <section class="relative isolate overflow-hidden bg-grad-hero">
      <HeroMesh />
      <div class="relative z-10 mx-auto max-w-6xl px-5 pb-20 pt-28 md:pb-28 md:pt-36">
        <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2">
          <div>
            <span class="inline-flex items-center gap-2 rounded-full border border-border-violet bg-violet/10 px-3 py-1 text-sm font-medium text-violet-text">
              <span class="ai-pulse inline-block h-1.5 w-1.5 rounded-full bg-violet"></span>
              AI-powered operating systems
            </span>

            <h1 class="mt-5 text-h1 text-white">
              Growing your business is making it <span class="grad-text">harder to run.</span>
            </h1>

            <p class="mt-6 max-w-xl leading-relaxed text-text-dim">
              Follow-ups drop. Handoffs break. The Monday report takes half of Monday. Duten Nexa
              builds the operating systems that let 5 to 200-person companies scale without the
              chaos scaling with them, with a ClickUp command center, connected tools, live
              dashboards, and AI agents doing the busywork.
            </p>

            <div class="mt-8 flex flex-wrap gap-4">
              <a href="/audit" class={btnPrimary}>Book an Automation Audit</a>
              <a href="/scorecard" class={btnSecondary}>Take the 2-Minute Scorecard</a>
            </div>

            <p class="mt-6 text-sm text-text-faint">
              Trusted by founders in the US, UK, Switzerland, and Australia.
            </p>

            <div class="mt-10 flex flex-wrap gap-x-10 gap-y-6">
              <div>
                <p class="text-3xl font-bold">
                  <span class="grad-text tabular-nums inline-block min-w-[3ch]" data-count="75" data-suffix="%">75%</span>
                </p>
                <p class="mt-1 text-sm text-text-dim">less manual reporting</p>
              </div>
              <div>
                <p class="text-3xl font-bold">
                  <span class="align-baseline text-base font-medium text-text-dim">up to</span>{' '}
                  <span class="grad-text tabular-nums inline-block min-w-[2.5ch]" data-count="80" data-suffix="%">80%</span>
                </p>
                <p class="mt-1 text-sm text-text-dim">fewer repetitive tasks</p>
              </div>
              <div>
                <p class="text-3xl font-bold">
                  <span class="grad-text-ai tabular-nums inline-block min-w-[1.5ch]" data-count="5" data-suffix=" days">5 days</span>
                </p>
                <p class="mt-1 text-sm text-text-dim">audit turnaround</p>
              </div>
            </div>
          </div>

          <div class="flex justify-center">
            <HeroStack />
          </div>
        </div>
      </div>
    </section>

    <!-- 2. The problem -->
    <section class="bg-navy py-20 md:py-28">
      <div class="mx-auto max-w-6xl px-5">
        <div class="reveal max-w-2xl" data-reveal>
          <h2 class="text-h2 text-white">Sound familiar?</h2>
          <p class="mt-4 text-text-dim">
            Every growing SMB hits the same wall around $500K in revenue. Not because the market
            isn't there, but because the inside of the business can't keep up with what the
            outside is doing.
          </p>
        </div>

        <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2">
          {painCards.map((card, i) => (
            <div
              class="reveal rounded-xl border border-border-soft bg-surface-card p-6 transition-[transform,border-color] duration-300 hover:-translate-y-1 hover:border-teal"
              data-reveal
              data-reveal-delay={i + 1}
            >
              <h3 class="text-lg font-semibold text-white">{card.title}</h3>
              <p class="mt-3 text-sm text-text-dim">{card.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 3. What we build -->
    <section class="bg-gradient-to-b from-navy to-navy-800 py-20 md:py-28" data-os-section>
      <div class="mx-auto max-w-6xl px-5">
        <div class="reveal max-w-2xl" data-reveal>
          <h2 class="text-h2 text-white">
            You don't need more tools. You need the ones you have to work together.
          </h2>
          <p class="mt-4 text-text-dim">We build one thing: an operating system. It has four layers.</p>
        </div>

        <div class="mt-12">
          <OSLayers />
        </div>

        <p class="reveal mt-12 text-center text-lg font-medium text-white" data-reveal>
          One story, one spine, not nine services.
        </p>
      </div>
    </section>

    <!-- 4. Proof strip -->
    <section class="overflow-hidden bg-navy py-20 md:py-28">
      <div class="mx-auto max-w-6xl px-5">
        <h2 class="reveal text-h2 text-white" data-reveal>Founders like you, work we've shipped.</h2>
      </div>
      <div class="mt-12">
        <TestimonialMarquee />
      </div>
    </section>

    <!-- 5. How it works -->
    <section class="bg-navy-800 py-20 md:py-28">
      <div class="mx-auto max-w-6xl px-5">
        <h2 class="reveal text-h2 text-center text-white" data-reveal>Three steps. No surprises.</h2>

        <div class="relative mt-14">
          <div class="absolute left-0 right-0 top-8 hidden md:block" aria-hidden="true">
            <div class="line-draw h-px w-full bg-gradient-to-r from-indigo to-teal" data-reveal></div>
          </div>

          <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            {steps.map((step, i) => (
              <div
                class="reveal relative rounded-xl border border-border-soft bg-surface-card p-6"
                data-reveal
                data-reveal-delay={i + 1}
              >
                <span class="grad-text text-sm font-bold">{step.number}</span>
                <h3 class="mt-2 text-lg font-semibold text-white">{step.title} - {step.subtitle}</h3>
                <p class="mt-3 text-sm text-text-dim">{step.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- 6. Featured case study (AI-tinted) -->
    <section class="bg-navy py-20 md:py-28">
      <div class="mx-auto max-w-6xl px-5">
        <div class="reveal overflow-hidden rounded-2xl bg-grad-ai p-8 md:p-12" data-reveal>
          <p class="text-sm font-semibold uppercase tracking-wide text-mint">Case study, Nerbugs · USA</p>
          <blockquote class="mt-4 max-w-3xl text-h2 text-white">
            &ldquo;The pipeline stopped leaking.&rdquo;
          </blockquote>
          <p class="mt-4 max-w-2xl text-text-dim">
            They optimized our ClickUp workspace, integrated Apollo CRM, and built automations
            that now handle our follow-ups automatically. The live dashboards completely changed
            how we make decisions.
            <span class="mt-2 block text-sm text-text-faint">Dr. Ronak Mehta, Founder, Nerbugs</span>
          </p>
          <a href="/case-studies/nerbugs" class="mt-6 inline-block font-medium text-mint hover:underline">
            Read the case study →
          </a>
        </div>
      </div>
    </section>

    <!-- 7. Final CTA band -->
    <section class="bg-navy">
      <div class="grid grid-cols-1 md:grid-cols-2">
        <div class="bg-grad-accent px-6 py-16 sm:px-10 md:px-16">
          <p class="max-w-md text-xl font-semibold text-navy">
            You've spent months guessing at what to fix. Spend 5 days actually knowing.
          </p>
          <a
            href="/audit"
            class="mt-8 inline-flex items-center justify-center rounded-lg bg-navy px-6 py-3 font-medium text-white transition-[transform,filter] duration-200 hover:scale-[1.02] hover:brightness-110"
          >
            Book an Automation Audit
          </a>
        </div>
        <div class="bg-navy px-6 py-16 sm:px-10 md:px-16">
          <p class="max-w-md text-xl font-semibold text-white">
            Not sure you're ready? Take the 2-minute Automation Readiness Scorecard.
          </p>
          <a href="/scorecard" class={`mt-8 ${btnSecondary}`}>Take the Scorecard</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
