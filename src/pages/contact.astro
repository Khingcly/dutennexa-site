---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';

const breakingOptions = [
  'Follow-ups',
  'Team visibility',
  'Reporting',
  'Tool integration',
  'AI agents',
  'Something else',
];
---

<Layout
  title="Contact Duten Nexa: Book a call, message us, or connect on WhatsApp"
  description="Book an Automation Audit, send us a message, or reach us on WhatsApp. We work UK and US business hours and reply within one business day."
>
  <Nav />
  <main>
    <PageHero
      title="Tell us what's breaking."
      sub="The fastest path is the 5-day Automation Audit. If you'd rather scope something first, drop us a message. We work UK and US business hours and reply within one business day."
    />

    <!-- Booking embed: placeholder pending the Zoho Bookings vs Calendly
         decision. Do not hardcode either provider's embed code until that's
         confirmed. HUMAN TASK. -->
    <section class="bg-navy py-16 md:py-24">
      <div class="mx-auto max-w-3xl px-5">
        <h2 class="reveal text-h2 text-center text-white" data-reveal>Book a call</h2>
        <div
          class="reveal mt-8 flex min-h-[320px] flex-col items-center justify-center rounded-xl border border-dashed border-white/20 bg-surface-card p-10 text-center"
          data-reveal
        >
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-text-faint">Booking embed placeholder</p>
          <p class="mt-3 max-w-md text-sm text-text-dim">
            This slot is reserved for the live booking calendar. HUMAN TASK: confirm Zoho Bookings vs Calendly,
            then the real embed goes here.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact form -->
    <section class="bg-navy-800 py-16 md:py-24">
      <div class="mx-auto max-w-2xl px-5">
        <h2 class="reveal text-h2 text-center text-white" data-reveal>Or send us a message</h2>
        <form id="contact-form" class="reveal mt-8 space-y-5" data-reveal novalidate>
          <div>
            <label for="cf-name" class="block text-sm font-medium text-text-dim">Name</label>
            <input
              id="cf-name"
              name="name"
              type="text"
              required
              class="mt-2 w-full rounded-lg border border-border-soft bg-surface-card px-4 py-3 text-white placeholder:text-text-faint focus:border-teal focus:outline-none"
            />
          </div>
          <div>
            <label for="cf-email" class="block text-sm font-medium text-text-dim">Email</label>
            <input
              id="cf-email"
              name="email"
              type="email"
              required
              class="mt-2 w-full rounded-lg border border-border-soft bg-surface-card px-4 py-3 text-white placeholder:text-text-faint focus:border-teal focus:outline-none"
            />
          </div>
          <div>
            <label for="cf-company" class="block text-sm font-medium text-text-dim">Company</label>
            <input
              id="cf-company"
              name="company"
              type="text"
              class="mt-2 w-full rounded-lg border border-border-soft bg-surface-card px-4 py-3 text-white placeholder:text-text-faint focus:border-teal focus:outline-none"
            />
          </div>
          <div>
            <label for="cf-breaking" class="block text-sm font-medium text-text-dim">What's breaking?</label>
            <select
              id="cf-breaking"
              name="breaking"
              required
              class="mt-2 w-full rounded-lg border border-border-soft bg-surface-card px-4 py-3 text-white focus:border-teal focus:outline-none"
            >
              <option value="" disabled selected>Choose one</option>
              {breakingOptions.map((opt) => <option value={opt}>{opt}</option>)}
            </select>
          </div>
          <div>
            <label for="cf-message" class="block text-sm font-medium text-text-dim">Message</label>
            <textarea
              id="cf-message"
              name="message"
              rows="5"
              required
              class="mt-2 w-full rounded-lg border border-border-soft bg-surface-card px-4 py-3 text-white placeholder:text-text-faint focus:border-teal focus:outline-none"
            ></textarea>
          </div>

          <!-- Honeypot: hidden from real visitors via CSS + off-screen positioning, not display:none (some bots skip display:none fields) -->
          <div class="absolute left-[-9999px]" aria-hidden="true">
            <label for="cf-website">Website</label>
            <input id="cf-website" name="website" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <button type="submit" class="cursor-button inline-flex w-full min-h-[52px] items-center justify-center rounded-lg bg-grad-accent px-6 py-3 font-medium text-navy transition-[filter] duration-200 hover:brightness-105 sm:w-auto">
            Send message
          </button>

          <p id="cf-status" class="text-sm text-text-dim" role="status" aria-live="polite"></p>
        </form>
      </div>
    </section>

    <!-- Other channels -->
    <section class="bg-navy py-16 md:py-24">
      <div class="mx-auto max-w-3xl px-5 text-center">
        <div class="reveal flex flex-wrap items-center justify-center gap-x-8 gap-y-4 text-sm text-text-dim" data-reveal>
          <a href="mailto:admin@dutennexa.com" class="cursor-link hover:text-white">admin@dutennexa.com</a>
          <span class="text-text-faint">·</span>
          <a
            href="https://wa.me/2349135732821"
            class="cursor-link hover:text-white"
            target="_blank"
            rel="noopener noreferrer"
          >
            WhatsApp Business
          </a>
          <span class="text-text-faint">·</span>
          <span class="text-text-faint">We work UK and US business hours.</span>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('cf-status');
  const webhookUrl = import.meta.env.PUBLIC_CONTACT_WEBHOOK_URL as string | undefined;

  function mailtoFallback(data: Record<string, string>) {
    const subject = encodeURIComponent(`Website enquiry: ${data.breaking || 'General'}`);
    const body = encodeURIComponent(
      `Name: ${data.name}\nEmail: ${data.email}\nCompany: ${data.company}\nWhat's breaking: ${data.breaking}\n\n${data.message}`
    );
    window.location.href = `mailto:admin@dutennexa.com?subject=${subject}&body=${body}`;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;

    const formData = new FormData(form);
    // Honeypot tripped: silently pretend success, drop the submission.
    if ((formData.get('website') as string)?.length) {
      status.textContent = "Thanks, we'll be in touch within one business day.";
      form.reset();
      return;
    }

    const data: Record<string, string> = {
      name: (formData.get('name') as string) || '',
      email: (formData.get('email') as string) || '',
      company: (formData.get('company') as string) || '',
      breaking: (formData.get('breaking') as string) || '',
      message: (formData.get('message') as string) || '',
    };

    status.textContent = 'Sending...';

    if (webhookUrl) {
      try {
        const res = await fetch(webhookUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error(`webhook responded ${res.status}`);
        status.textContent = "Thanks, we'll be in touch within one business day.";
        form.reset();
        return;
      } catch (err) {
        // Fall through to mailto fallback below; never leave a submission
        // stuck client-side only.
      }
    }

    status.textContent = "Opening your email client to send this instead...";
    mailtoFallback(data);
  });
</script>
