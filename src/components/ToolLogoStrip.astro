---
// Real, official brand marks only, sourced from simple-icons (CC0-licensed,
// unmodified monochrome outlines maintained for exactly this "works with"
// use case). ClickUp / Make / Zapier / Google Analytics / Google Sheets are
// available there.
//
// Excel's real official icon (public/brand/excel.png) was supplied directly
// by the human and committed to the repo; simple-icons doesn't carry it.
// The source file had a solid black canvas baked in (not real transparency),
// keyed out programmatically since black isn't part of the icon's actual
// design (confirmed by sampling all four corners before touching it).
// Rendered as an <img> with a grayscale-by-default filter so it dims/
// brightens on hover the same way the SVG icons do, instead of always
// showing full color while its neighbors are dimmed.
//
// NEEDS ASSET: Power BI and Power Automate are still real gaps. Microsoft
// doesn't license those into open icon sets, and this build environment's
// network policy blocks reaching Microsoft's brand pages or CDN directly.
// Human task: same process as Excel, supply the official files and I'll
// swap these two remaining placeholders for the real marks.
import { siClickup, siMake, siZapier, siGoogleanalytics, siGooglesheets } from 'simple-icons';

const tools = [
  { name: 'ClickUp', icon: siClickup },
  { name: 'Make', icon: siMake },
  { name: 'Zapier', icon: siZapier },
  { name: 'Google Analytics', icon: siGoogleanalytics },
  { name: 'Google Sheets', icon: siGooglesheets },
];

const rasterTools = [{ name: 'Excel', src: '/brand/excel.png' }];

const pending = ['Power BI', 'Power Automate'];
---

<div class="reveal border-y border-border-soft bg-navy-900/60 py-8" data-reveal>
  <div class="mx-auto max-w-6xl px-5">
    <p class="text-center text-xs font-medium uppercase tracking-[0.14em] text-text-faint">
      Built on the tools you already run
    </p>
    <div class="mt-6 flex flex-wrap items-center justify-center gap-x-10 gap-y-5">
      {tools.map((t) => (
        <div
          class="cursor-link flex items-center text-white/50 transition-colors duration-200 hover:text-[var(--brand)]"
          style={`--brand:#${t.icon.hex}`}
        >
          <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor" aria-hidden="true">
            <path d={t.icon.path}></path>
          </svg>
          <span class="sr-only">{t.name}</span>
        </div>
      ))}
      {rasterTools.map((t) => (
        <div class="cursor-link flex items-center">
          <img
            src={t.src}
            alt={t.name}
            width="26"
            height="26"
            class="tool-raster-icon opacity-50 grayscale transition-[filter,opacity] duration-200 hover:opacity-100 hover:grayscale-0"
          />
        </div>
      ))}
      {pending.map((name) => (
        <div
          class="rounded border border-dashed border-white/15 px-2.5 py-1 text-[11px] text-text-faint"
          title={`${name} logo pending official brand asset`}
        >
          {name}
        </div>
      ))}
    </div>
  </div>
</div>
