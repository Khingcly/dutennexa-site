---
// Calendly inline widget, shared by /audit and /contact so the card,
// loading state, and init logic only exist once.
//
// Calendly's inline widget is light-themed by default; the background/
// text/primary color URL params that would theme it dark require
// Calendly's Standard plan or above, and even then some inner elements
// (the expandable event-details toggle especially) don't fully respect
// them. Rather than fighting that, the widget sits in a dedicated light
// card (near-white background, teal-tinted border) that reads as
// intentional against the navy page regardless of whether the color
// params actually take.
//
// import.meta.env only resolves in frontmatter/modules, not inside a
// define:vars script (Astro treats those as plain inline scripts), so
// it's read here and passed through define:vars below, same pattern as
// scorecard.astro's webhook URL.
const calendlyUrl = import.meta.env.PUBLIC_CALENDLY_URL ?? '';
---

<div class="calendly-card relative overflow-hidden rounded-2xl border border-teal/30 bg-[#FAFAFA] p-6 shadow-[0_0_32px_rgba(63,224,208,0.08)] md:p-8">
  <div
    id="calendly-skeleton"
    class="calendly-skeleton absolute inset-6 flex flex-col items-center justify-center gap-3 rounded-xl bg-[#F0F0F0] md:inset-8"
    aria-hidden="true"
  >
    <div class="h-8 w-8 animate-spin rounded-full border-2 border-navy/15 border-t-navy/50"></div>
    <p class="text-xs font-medium uppercase tracking-wide text-navy/40">Loading availability…</p>
  </div>
  <div id="calendly-embed" style="min-width:320px;height:700px;width:100%;"></div>
</div>

<script define:vars={{ calendlyUrl }}>
  if (calendlyUrl) {
    const skeleton = document.getElementById('calendly-skeleton');
    const container = document.getElementById('calendly-embed');
    let revealed = false;

    function revealWidget() {
      if (revealed) return;
      revealed = true;
      if (skeleton) skeleton.style.display = 'none';
    }

    window.addEventListener('message', (e) => {
      if (typeof e.data?.event === 'string' && e.data.event.indexOf('calendly.') === 0) {
        revealWidget();
      }
    });
    // Safety net: some ad/tracker blockers eat Calendly's postMessage
    // events even though the iframe itself renders fine, don't leave the
    // skeleton spinning forever in that case.
    setTimeout(revealWidget, 6000);

    const script = document.createElement('script');
    script.src = 'https://assets.calendly.com/assets/external/widget.js';
    script.async = true;
    script.onload = () => {
      if (window.Calendly && container) {
        const separator = calendlyUrl.includes('?') ? '&' : '?';
        window.Calendly.initInlineWidget({
          url: `${calendlyUrl}${separator}hide_event_type_details=1&hide_gdpr_banner=1&background_color=002141&text_color=002141&primary_color=3fe0d0`,
          parentElement: container,
          resize: true,
        });
      }
    };
    script.onerror = () => {
      revealWidget();
      if (container) {
        container.innerHTML =
          '<div class="flex h-full items-center justify-center px-4 text-center text-sm text-navy/50">Booking calendar unavailable right now, use the email link below.</div>';
      }
    };
    document.body.appendChild(script);
  } else {
    const skeleton = document.getElementById('calendly-skeleton');
    if (skeleton) {
      skeleton.innerHTML =
        '<p class="text-sm text-navy/50 px-4 text-center">Booking calendar unavailable right now, use the email link below.</p>';
    }
  }
</script>

<style>
  @media (prefers-reduced-motion: reduce) {
    .calendly-skeleton [class*='animate-spin'] {
      animation: none;
    }
  }
</style>
