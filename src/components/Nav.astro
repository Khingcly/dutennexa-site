---
const links = [
  { href: '/#what-we-build', label: 'What we build' },
  { href: '/#proof', label: 'Proof' },
  { href: '/#how-it-works', label: 'How it works' },
  { href: '/case-studies', label: 'Case studies' },
];
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 border-b border-transparent transition-[background-color,backdrop-filter,border-color,padding] duration-300"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
    <a href="/" class="flex shrink-0 items-center gap-2.5 cursor-link">
      <img src="/brand/logo-on-navy.png" alt="Duten Nexa" class="h-6 w-auto" />
      <span class="hidden flex-col leading-none sm:flex">
        <span class="text-[11px] font-semibold tracking-[0.16em] text-white">DUTEN NEXA</span>
        <span class="text-[9px] font-medium tracking-[0.22em] text-text-faint">OPERATING SYSTEM</span>
      </span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Primary">
      {links.map((link) => (
        <a
          href={link.href}
          class="cursor-link text-sm font-medium text-text-dim transition-colors hover:text-white"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-5 md:flex">
      <span class="flex items-center gap-1.5 text-[10px] font-semibold tracking-[0.14em] text-teal">
        <span class="ai-pulse inline-block h-1.5 w-1.5 rounded-full bg-teal"></span>
        ALL SYSTEMS LIVE
      </span>
      <a
        href="/audit"
        class="cursor-button rounded-lg bg-grad-accent px-6 py-3 text-sm font-medium text-navy transition-[transform,filter] duration-200 hover:brightness-105"
      >
        Book an Audit
      </a>
    </div>

    <button
      id="nav-toggle"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-mobile-menu"
      class="flex h-10 w-10 flex-col items-center justify-center gap-1.5 md:hidden"
    >
      <span class="h-0.5 w-6 bg-white"></span>
      <span class="h-0.5 w-6 bg-white"></span>
      <span class="h-0.5 w-6 bg-white"></span>
    </button>
  </div>

  <div id="nav-mobile-menu" class="flex-col items-center justify-center gap-8 bg-navy-900">
    <nav class="flex flex-col items-center gap-8" aria-label="Mobile">
      {links.map((link) => (
        <a href={link.href} class="text-2xl font-medium text-white">
          {link.label}
        </a>
      ))}
    </nav>
    <a href="/audit" class="rounded-lg bg-grad-accent px-6 py-3 text-base font-medium text-navy">
      Book an Audit
    </a>
  </div>
</header>

<style>
  #site-nav.scrolled {
    background-color: rgba(0, 22, 40, 0.82);
    backdrop-filter: blur(10px);
    border-bottom-color: var(--border-soft);
  }
  #site-nav.scrolled .px-5 {
    padding-top: 0.625rem;
    padding-bottom: 0.625rem;
  }
  #nav-mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 40;
  }
  #nav-mobile-menu.is-open {
    display: flex;
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile-menu');

  let ticking = false;
  const onScroll = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      nav?.classList.toggle('scrolled', window.scrollY > 40);
      ticking = false;
    });
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    toggle.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Open menu');
    });
  });
</script>
