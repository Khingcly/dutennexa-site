---
const layers = [
  { title: 'ClickUp', body: 'the command center [NEEDS INPUT — complete one-liner]', ai: false },
  { title: 'Make', body: 'the nervous system [NEEDS INPUT — complete one-liner]', ai: false },
  {
    title: 'Dashboards',
    body: 'the eyes. Clients have cut manual reporting time by up to 75%.',
    ai: false,
  },
  { title: 'AI agents', body: 'the muscle [NEEDS INPUT — complete one-liner]', ai: true },
];
---

<div class="relative">
  <!-- Horizontal connector + scroll-linked pulse (desktop). The clip band is
       10px tall (to show the dot) and overflow-hidden, so the full-width mover's
       translateX(100%) sweep is clipped instead of extending the page width. -->
  <div class="absolute left-0 right-0 top-6 hidden h-2.5 -translate-y-1/2 overflow-hidden md:block" aria-hidden="true">
    <div class="line-draw absolute left-0 top-1/2 h-px w-full bg-gradient-to-r from-teal via-indigo to-violet" data-reveal></div>
    <div data-os-pulse class="pointer-events-none absolute inset-y-0 left-0 w-full opacity-0">
      <span class="absolute left-0 top-1/2 h-2.5 w-2.5 -translate-y-1/2 rounded-full bg-mint shadow-[0_0_8px_2px_rgba(139,245,232,0.6)]"></span>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-4 md:gap-4">
    {layers.map((layer, i) => (
      <div
        class:list={[
          'relative reveal rounded-xl border bg-surface-card p-6',
          layer.ai ? 'border-border-violet' : 'border-border-teal',
        ]}
        data-reveal
        data-reveal-delay={i + 1}
      >
        <span
          class:list={[
            'mb-4 hidden h-3 w-3 rounded-full md:block',
            layer.ai ? 'bg-violet' : 'bg-teal',
          ]}
          aria-hidden="true"
        ></span>
        <h3 class:list={['text-lg font-semibold', layer.ai ? 'text-violet-text' : 'text-white']}>
          {layer.title}
        </h3>
        <p class="mt-2 text-sm text-text-dim">{layer.body}</p>
      </div>
    ))}
  </div>
</div>
