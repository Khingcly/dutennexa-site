---
// Real, official brand marks (simple-icons, CC0) on the ClickUp/Make/
// Dashboards frames so the tools read as instantly recognizable rather than
// making visitors guess from a text label alone — same sourcing rule as
// ToolLogoStrip.astro (real marks only, never hand-drawn). "AI agents" is
// Duten Nexa's own build, not a resold product, so it keeps the plain
// violet dot instead of a third-party logo.
import { siClickup, siMake, siGooglesheets } from 'simple-icons';

const frames = [
  {
    title: 'ClickUp',
    tag: 'the command center',
    body: 'Every project, task, and handoff in one workspace, structured to how you actually run.',
    ai: false,
    icon: siClickup,
  },
  {
    title: 'Make',
    tag: 'the nervous system',
    body: 'Your tools finally talk. Leads route themselves. Invoices trigger themselves. Nothing waits on someone remembering.',
    ai: false,
    icon: siMake,
  },
  {
    title: 'Dashboards',
    tag: 'the eyes',
    body: 'Sales, delivery, cash, team load, visible in one place, refreshed automatically. Clients have cut manual reporting time by up to 75%.',
    ai: false,
    icon: siGooglesheets,
  },
  {
    title: 'AI agents',
    tag: 'the muscle',
    body: "Qualify inbound. Handle Tier 1 support. Research prospects. The work you'd hire someone to do, without hiring someone to do it.",
    ai: true,
    icon: null,
  },
];
---

<section id="what-we-build" class="bg-gradient-to-b from-navy to-navy-800">
  <div class="mx-auto max-w-6xl px-5 pt-16 md:pt-24">
    <div class="reveal mx-auto max-w-2xl text-center" data-reveal>
      <h2 class="text-h2 text-white">
        You don't need more tools. You need the ones you have to work together.
      </h2>
      <p class="mt-4 text-text-dim">We build one thing: an operating system. It has four layers.</p>
    </div>
  </div>

  <!-- Desktop / tablet: pinned orbit sequence. Section is tall (400vh);
       the inner wrapper sticks to the viewport while the user scrolls
       through it. All 4 frames sit on a circle around a shared center point,
       echoing the hub-and-spoke topology diagram in the hero: motion.js
       computes each card's angle from continuous scroll progress and pulls
       whichever card is angularly closest to "front" into the center at
       full size and opacity, while the other 3 stay out on the ring,
       smaller and dimmer. As you scroll, the whole ring rotates so each
       card takes its turn passing through the center.
       A small persistent eyebrow + progress bar stay pinned alongside the
       ring the whole time, so it never reads as a card floating with no
       context once the full heading above has scrolled out of view. -->
  <div class="pin-outer hidden md:block" data-pin-section>
    <div class="pin-sticky">
      <div class="mx-auto w-full max-w-3xl px-5 text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-text-faint">What we build</p>

        <div class="relative mt-8 h-[480px]" data-pin-stage>
          <div class="orbit-ring pointer-events-none absolute left-1/2 top-1/2 -z-10 rounded-full border border-dashed border-white/10" aria-hidden="true"></div>
          {frames.map((f, i) => (
            <div class={`pin-frame ${f.ai ? 'cursor-ai' : ''}`} data-pin-frame>
              <div class="orbit-card" data-orbit-card>
                <div class={`w-full max-w-sm rounded-2xl border p-8 shadow-2xl shadow-navy-900/60 md:p-9 ${f.ai ? 'ai-bloom border-border-violet bg-violet/10' : 'border-border-teal bg-surface-card'}`}>
                  <div class="flex justify-center">
                    {f.icon ? (
                      <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-white shadow-md" style={`--brand:#${f.icon.hex}`}>
                        <svg viewBox="0 0 24 24" width="26" height="26" fill="var(--brand)" aria-hidden="true"><path d={f.icon.path}></path></svg>
                      </span>
                    ) : (
                      <span class="flex h-12 w-12 items-center justify-center rounded-xl border border-border-violet bg-violet/15">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--violet-text)" stroke-width="1.6" aria-hidden="true">
                          <path d="M12 2 L14 9 L21 11 L14 13 L12 20 L10 13 L3 11 L10 9 Z" stroke-linejoin="round" />
                        </svg>
                      </span>
                    )}
                  </div>
                  <span class={`mt-4 block text-center text-xs font-semibold tracking-[0.2em] ${f.ai ? 'text-violet-text' : 'text-teal'}`}>
                    0{i + 1} / 04
                  </span>
                  <h3 class={`mt-3 text-center text-3xl font-bold md:text-4xl ${f.ai ? 'text-violet-text' : 'text-white'}`}>{f.title}</h3>
                  <p class="mt-2 text-center text-base text-text-faint">{f.tag}</p>
                  <p class="mx-auto mt-6 max-w-md text-center text-lg leading-relaxed text-text-dim">{f.body}</p>
                </div>
              </div>
              <div class="orbit-node" data-orbit-node aria-hidden="true">
                <div class={`flex items-center gap-2 rounded-full border px-3 py-2 shadow-lg shadow-navy-900/50 ${f.ai ? 'border-border-violet bg-violet/15' : 'border-border-teal bg-surface-card'}`}>
                  {f.icon ? (
                    <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-white" style={`--brand:#${f.icon.hex}`}>
                      <svg viewBox="0 0 24 24" width="12" height="12" fill="var(--brand)" aria-hidden="true"><path d={f.icon.path}></path></svg>
                    </span>
                  ) : (
                    <span class="h-2 w-2 shrink-0 rounded-full bg-violet"></span>
                  )}
                  <span class="whitespace-nowrap text-sm font-semibold text-white">{f.title}</span>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 flex items-center justify-center gap-3" id="pin-progress">
          {frames.map((f, i) => (
            <span
              class={`h-1.5 w-8 rounded-full transition-colors duration-300 ${f.ai ? 'bg-violet/25' : 'bg-white/15'}`}
              data-pin-progress={i}
            ></span>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile: horizontal scroll-snap swipe deck instead of scroll-pinning -->
  <div class="px-5 pb-4 pt-10 md:hidden">
    <div id="swipe-deck" class="flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2">
      {frames.map((f, i) => (
        <div
          class={`swipe-card w-[85%] shrink-0 snap-center rounded-2xl border p-7 text-center ${f.ai ? 'border-border-violet bg-violet/10' : 'border-border-teal bg-surface-card'}`}
          data-swipe-index={i}
        >
          <div class="flex justify-center">
            {f.icon ? (
              <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-white shadow-md" style={`--brand:#${f.icon.hex}`}>
                <svg viewBox="0 0 24 24" width="22" height="22" fill="var(--brand)" aria-hidden="true"><path d={f.icon.path}></path></svg>
              </span>
            ) : (
              <span class="flex h-10 w-10 items-center justify-center rounded-xl border border-border-violet bg-violet/15">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--violet-text)" stroke-width="1.6" aria-hidden="true">
                  <path d="M12 2 L14 9 L21 11 L14 13 L12 20 L10 13 L3 11 L10 9 Z" stroke-linejoin="round" />
                </svg>
              </span>
            )}
          </div>
          <span class={`mt-3 block text-xs font-semibold tracking-[0.14em] ${f.ai ? 'text-violet-text' : 'text-teal'}`}>
            0{i + 1} / 04
          </span>
          <h3 class={`mt-3 text-xl font-bold ${f.ai ? 'text-violet-text' : 'text-white'}`}>{f.title}</h3>
          <p class="mt-1 text-sm text-text-faint">{f.tag}</p>
          <p class="mt-4 text-sm text-text-dim">{f.body}</p>
        </div>
      ))}
    </div>
    <div id="swipe-pips" class="mt-4 flex justify-center gap-2">
      {frames.map((f, i) => (
        <span class={`h-1.5 w-1.5 rounded-full transition-colors ${f.ai ? 'bg-violet/30' : 'bg-white/20'}`} data-pip={i}></span>
      ))}
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-5 pb-16 md:pb-24">
    <p class="reveal mt-4 text-center text-lg font-medium text-white" data-reveal>
      One story, one spine, not nine services.
    </p>
  </div>
</section>

<style>
  .pin-outer {
    height: 400vh;
    position: relative;
  }
  .pin-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .pin-frame {
    position: absolute;
    inset: 0;
    padding: 0 1.25rem;
  }
  .orbit-card,
  .orbit-node {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .orbit-node {
    pointer-events: none;
  }
  .orbit-ring {
    width: 460px;
    height: 460px;
    transform: translate(-50%, -50%);
  }

  .swipe-card {
    scroll-snap-stop: always;
    transition: transform 0.2s ease, opacity 0.2s ease, box-shadow 0.2s ease;
  }
  .swipe-card.is-active {
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.35);
  }
  #swipe-pips span.active {
    background: var(--teal);
  }
  #swipe-pips span[data-pip='3'].active {
    background: var(--violet);
  }
  #pin-progress span.active {
    background: var(--teal);
  }
  #pin-progress span[data-pin-progress='3'].active {
    background: var(--violet);
  }

  @media (prefers-reduced-motion: reduce) {
    .pin-outer {
      height: auto !important;
    }
    .pin-sticky {
      position: static !important;
      height: auto !important;
      display: block !important;
      padding: 2rem 0;
    }
    .pin-frame {
      position: static !important;
      margin-bottom: 1.5rem;
    }
    .orbit-card {
      position: static !important;
      opacity: 1 !important;
      transform: none !important;
      filter: none !important;
    }
    .orbit-node,
    .orbit-ring {
      display: none !important;
    }
  }
</style>

<script>
  const deck = document.getElementById('swipe-deck');
  const pips = document.querySelectorAll('#swipe-pips [data-pip]');
  const reduceSwipe = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (deck && pips.length) {
    const cards = [...deck.querySelectorAll('[data-swipe-index]')];
    let ticking = false;
    const update = () => {
      const center = deck.scrollLeft + deck.clientWidth / 2;
      let closest = 0;
      let closestDist = Infinity;
      cards.forEach((card, i) => {
        const el = card as HTMLElement;
        const dist = Math.abs(el.offsetLeft + el.offsetWidth / 2 - center);
        if (dist < closestDist) {
          closestDist = dist;
          closest = i;
        }
        if (!reduceSwipe) {
          // Coverflow-lite: the card nearest the snap center sits full size
          // and opacity; cards drifting toward the edges shrink and dim,
          // continuously tracking native scroll position (no scroll-jacking).
          const t = Math.min(dist / el.offsetWidth, 1);
          el.style.transform = `scale(${(1 - t * 0.12).toFixed(3)})`;
          el.style.opacity = Math.max(0.45, 1 - t * 0.55).toFixed(2);
        }
      });
      pips.forEach((p, i) => p.classList.toggle('active', i === closest));
      cards.forEach((card, i) => card.classList.toggle('is-active', i === closest));
      ticking = false;
    };
    update();
    deck.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      },
      { passive: true }
    );
  }
</script>
